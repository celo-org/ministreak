# Deployer private key (with 0x prefix)
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# RPC URLs
CELO_SEPOLIA_RPC_URL=https://forno.celo-sepolia.celo-testnet.org
CELO_RPC_URL=https://forno.celo.org
ALFAJORES_RPC_URL=https://alfajores-forno.celo-testnet.org

# Treasury address that receives the 5% protocol fee
TREASURY_ADDRESS=0xYOUR_TREASURY_ADDRESS

# Oracle hot wallet address (the backend submitter)
ORACLE_HOT_WALLET=0xYOUR_ORACLE_HOT_WALLET_ADDRESS

# USDT address override (leave blank for Celo Sepolia / Mainnet defaults in deploy.ts)
# Celo Mainnet USDT: 0x48065fbBE25f71C9282ddf5e1cD6D6A887483D5e (verify at celoscan.io)
USDT_ADDRESS=

# Block explorer API keys
# Blockscout (Celo Sepolia) — API key may not be required
BLOCKSCOUT_API_KEY=placeholder
# Celoscan (Mainnet / Alfajores)
CELOSCAN_API_KEY=YOUR_CELOSCAN_API_KEY

# Enable gas reporting in tests
REPORT_GAS=false
